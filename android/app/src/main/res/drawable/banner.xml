<?xml version="1.0" encoding="utf-8"?>
<!-- Android TV Leanback launcher banner (320x180). The launcher overlays the app
     label below the banner, so no text needed here. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="320dp"
    android:height="180dp"
    android:viewportWidth="320"
    android:viewportHeight="180">

    <!-- Background -->
    <path
        android:pathData="M0,0h320v180h-320z"
        android:fillColor="#0A0D14" />

    <!-- Soft diagonal panel overlay -->
    <path
        android:pathData="M0,0L320,0L260,180L0,180Z"
        android:fillColor="#14171F" />

    <!-- Bottom accent stripe -->
    <path
        android:pathData="M0,170h320v10h-320z"
        android:fillColor="#4ADE80"
        android:fillAlpha="0.85" />

    <!-- Music note glyph (Material `music_note`, scaled to ~96 logical units) -->
    <group
        android:translateX="32"
        android:translateY="42">
        <group android:scaleX="4" android:scaleY="4">
            <path
                android:fillColor="#4ADE80"
                android:pathData="M12,3v9.28A4.39,4.39 0,0 0,10.5 12C8.57,12 7,13.57 7,15.5S8.57,19 10.5,19s3.5,-1.57 3.5,-3.5V6h4V3H12z" />
        </group>
    </group>

    <!-- Subtle dot row, decorative -->
    <path android:pathData="M160,60h2v2h-2z" android:fillColor="#4ADE80" android:fillAlpha="0.4" />
    <path android:pathData="M180,60h2v2h-2z" android:fillColor="#4ADE80" android:fillAlpha="0.6" />
    <path android:pathData="M200,60h2v2h-2z" android:fillColor="#4ADE80" android:fillAlpha="0.8" />
    <path android:pathData="M220,60h2v2h-2z" android:fillColor="#4ADE80" />
</vector>
